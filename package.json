{
	"name": "devspaces-remote-ssh",
	"displayName": "Dev Spaces Local/Remote Support - SSH",
	"description": "Support for connecting a local VS Code instance to a Dev Workspace under Red Hat OpenShift Dev Spaces over SSH",
	"version": "0.0.1",
	"publisher": "redhat",
	"repository": "https://github.com/redhat-developer/vscode-devspaces",
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"Kubernetes",
		"Openshift",
		"remote development",
		"remote",
		"ssh"
	],
	"activationEvents": [
		"onView:remoteTargets"
	],
	"main": "./out/extension.js",
	"contributes": {
		"menus": {
			"view/item/context": [
				{
					"command": "devspaces.connect.cluster",
					"group": "navigation",
					"when": "viewItem == remote-explorer.sshGroup"
				},
				{
					"command": "devspaces.connect.cluster",
					"group": "inline",
					"when": "viewItem == remote-explorer.sshGroup"
				}
			],
			"view/title": [
				{
					"command": "devspaces.connect.cluster",
					"group": "navigation",
					"when": "view == remoteTargets"
				},
				{
					"command": "devspaces.connect.cluster",
					"group": "inline",
					"when": "view == remoteTargets"
				}
			]
		},
		"commands": [
			{
				"command": "devspaces.connect.cluster",
				"title": "Connect to Dev Spaces",
				"icon": {
					"light": "images/devspaces-icon.png",
					"dark": "images/devspaces-icon.png"
				}
			},
			{
				"command": "devspaces.get.devworkspaces",
				"title": "Get Dev Workspaces"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -watch -p ./"
	},
	"dependencies": {
		"ssh-config": "^5.0.4"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/vscode": "^1.100.0",
		"eslint": "^9.39.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	}
}
